<Window
    x:Class="CanViewer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CAN Bus Viewer (WinUI 3)">
    <Grid x:Name="RootGrid" Background="#0C1424" RequestedTheme="Dark">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="12,12,12,8" Padding="10" CornerRadius="10" BorderThickness="1" BorderBrush="#2A5EA8" Background="#111D33">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="InterfaceComboBox" Width="120" />
                <ComboBox x:Name="ChannelComboBox" Width="170" IsEditable="True" />
                <ComboBox x:Name="BitrateComboBox" Width="120" IsEditable="True">
                    <x:String>125000</x:String>
                    <x:String>250000</x:String>
                    <x:String>500000</x:String>
                    <x:String>1000000</x:String>
                </ComboBox>
                <Button Content="Scan" Click="OnScanClick" />
                <Button Content="Connect" Click="OnConnectClick" />
                <Button Content="Disconnect" Click="OnDisconnectClick" />
                <TextBlock VerticalAlignment="Center" Text="{Binding StatusText}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="12,0,12,8" Padding="10" CornerRadius="10" BorderThickness="1" BorderBrush="#2A5EA8" Background="#111D33">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Messages:" FontWeight="SemiBold" />
                <TextBlock x:Name="MessageCountText" Text="0" />
                <TextBlock Text="Trigger Hits:" FontWeight="SemiBold" />
                <TextBlock x:Name="TriggerCountText" Text="0" />
                <TextBlock Text="Dropped:" FontWeight="SemiBold" />
                <TextBlock x:Name="DroppedCountText" Text="0" />
                <CheckBox x:Name="AutoScrollCheckBox" Content="Auto-scroll" IsChecked="True" />
                <Button Content="Pause" Click="OnPauseClick" />
                <Button Content="Play" Click="OnPlayClick" />
                <Button Content="Clear All" Click="OnClearAllClick" />
                <TextBlock Text="Queue:" FontWeight="SemiBold" />
                <TextBlock x:Name="QueueDepthText" Text="0" />
                <TextBlock Text="Render 1/" FontWeight="SemiBold" />
                <TextBlock x:Name="RenderStrideText" Text="1" />
                <TextBlock Text="Decode 1/" FontWeight="SemiBold" />
                <TextBlock x:Name="DecodeStrideText" Text="1" />
                <TextBlock Text="UI ms:" FontWeight="SemiBold" />
                <TextBlock x:Name="UiFlushMsText" Text="0.0" />
                <TextBlock Text="Sampled:" FontWeight="SemiBold" />
                <TextBlock x:Name="SampledOutText" Text="0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="12,0,12,12" Padding="10" CornerRadius="10" BorderThickness="1" BorderBrush="#2A5EA8" Background="#111D33">
            <Pivot x:Name="MainPivot">
                <PivotItem Header="Raw">
                    <Grid Margin="4" RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Mode:" />
                            <ComboBox x:Name="RawModeComboBox" Width="170" SelectionChanged="OnRawModeChanged">
                                <x:String>All frames</x:String>
                                <x:String>Latest per ID</x:String>
                            </ComboBox>
                        </StackPanel>
                        <Grid Grid.Row="1" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timestamp" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Rel (s)" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Arb ID" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Data (hex)" FontWeight="SemiBold" />
                        </Grid>
                        <ListView Grid.Row="2" x:Name="RawListView" ItemsSource="{Binding RawRows}" SelectionMode="None" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1" Text="{Binding RelativeSeconds}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ArbitrationIdHex}" />
                                        <TextBlock Grid.Column="3" Text="{Binding DataHex}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Inspect">
                    <Grid Margin="4" RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Mode:" />
                            <ComboBox x:Name="InspectModeComboBox" Width="170" SelectionChanged="OnInspectModeChanged">
                                <x:String>All frames</x:String>
                                <x:String>Latest per ID</x:String>
                            </ComboBox>
                        </StackPanel>
                        <Grid Grid.Row="1" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timestamp" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Rel (s)" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Arb ID" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Raw Data" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Symbolic" FontWeight="SemiBold" />
                        </Grid>
                        <ListView Grid.Row="2" ItemsSource="{Binding InspectRows}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="260" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1" Text="{Binding RelativeSeconds}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ArbitrationIdHex}" />
                                        <TextBlock Grid.Column="3" Text="{Binding RawDataHex}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Symbolic}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Send">
                    <Grid Margin="8" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Raw Send" FontWeight="SemiBold" />
                        <StackPanel Grid.Row="1" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock VerticalAlignment="Center" Text="Arb ID (hex)" />
                                <TextBox x:Name="SendArbIdTextBox" Width="120" Text="123" />
                                <TextBlock VerticalAlignment="Center" Text="Data (hex bytes)" />
                                <TextBox x:Name="SendDataTextBox" Width="320" Text="01 02 03 04" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox x:Name="SendExtendedCheckBox" Content="Extended ID" />
                                <CheckBox x:Name="SendPeriodicCheckBox" Content="Periodic" />
                                <TextBlock VerticalAlignment="Center" Text="Period ms" />
                                <TextBox x:Name="SendPeriodMsTextBox" Width="90" Text="100" />
                                <Button Content="Send Once" Click="OnSendRawFrameClick" />
                                <Button Content="Start Periodic" Click="OnStartPeriodicSendClick" />
                                <Button Content="Stop Periodic" Click="OnStopPeriodicSendClick" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="2" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Symbolic Send Cards (DBC)" FontWeight="SemiBold" />
                                <Button Content="+ Add Card" Click="OnAddSymbolicCardClick" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Each card has its own message and periodic toggle." />
                            </StackPanel>
                            <ScrollViewer Grid.Row="2">
                                <ItemsControl ItemsSource="{Binding SymbolicCards}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8" Padding="8" CornerRadius="8" BorderThickness="1" BorderBrush="#2A5EA8" Background="#0E1A30">
                                                <Grid RowSpacing="6">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ComboBox Width="320" ItemsSource="{Binding MessageOptions}" SelectedItem="{Binding MessageDisplay, Mode=TwoWay}" SelectionChanged="OnCardMessageChanged" />
                                                        <CheckBox Content="Periodic" IsChecked="{Binding IsPeriodic, Mode=TwoWay}" Checked="OnCardPeriodicChecked" Unchecked="OnCardPeriodicUnchecked" />
                                                        <TextBox Width="90" Text="{Binding PeriodMs, Mode=TwoWay}" />
                                                        <Button Content="Send" Click="OnCardSendClick" />
                                                        <Button Content="Remove" Click="OnCardRemoveClick" />
                                                    </StackPanel>
                                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Signals}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid ColumnSpacing="8" Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="200" />
                                                                        <ColumnDefinition Width="120" />
                                                                        <ColumnDefinition Width="120" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                                                    <TextBox Grid.Column="1" Text="{Binding ValueText, Mode=TwoWay}" />
                                                                    <TextBlock Grid.Column="2" Text="{Binding Unit}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Decode">
                    <Grid Margin="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="120" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox
                                x:Name="DbcPathTextBox"
                                Width="520"
                                PlaceholderText="DBC file path (.dbc)" />
                            <Button Content="Browse/Add DBC" Click="OnAddDbcClick" />
                            <Button Content="Remove Selected DBC" Click="OnRemoveDbcClick" />
                        </StackPanel>
                        <ListView x:Name="DbcFilesListView" Grid.Row="1" ItemsSource="{Binding DbcFiles}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Path}" />
                                        <TextBlock Grid.Column="1" Text="{Binding MessageCount}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="DecodeWatchComboBox" Grid.Column="0" />
                            <Button Grid.Column="1" Content="+ Watch" Click="OnAddDecodeWatchClick" />
                            <Button Grid.Column="2" Content="- Watch" Click="OnRemoveDecodeWatchClick" />
                            <Button Grid.Column="3" Content="Clear Watch" Click="OnClearDecodeWatchClick" />
                            <ListView x:Name="DecodeWatchListView" Grid.Column="4" MaxHeight="90" />
                        </Grid>
                        <ScrollViewer Grid.Row="3">
                            <ItemsControl ItemsSource="{Binding DecodedGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="True" Margin="0,0,0,6">
                                            <Expander.Header>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="260" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="100" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ArbitrationIdHex}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Timestamp}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding RelativeSeconds}" />
                                                </Grid>
                                            </Expander.Header>
                                            <ItemsControl ItemsSource="{Binding Signals}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnSpacing="8" Margin="24,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="220" />
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="80" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="100" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding SignalName}" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Value}" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Unit}" />
                                                            <TextBlock Grid.Column="3" Text="{Binding Minimum}" />
                                                            <TextBlock Grid.Column="4" Text="{Binding Maximum}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Replay">
                    <Grid Margin="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="ReplayPathTextBox" Width="520" PlaceholderText="Replay CSV path (rel_seconds,arb_id_hex,data_hex)" />
                            <Button Content="Load" Click="OnLoadReplayClick" />
                            <Button Content="Start" Click="OnStartReplayClick" />
                            <Button Content="Stop" Click="OnStopReplayClick" />
                        </StackPanel>
                        <ListView Grid.Row="1" ItemsSource="{Binding ReplayRows}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" />
                                        <TextBlock Grid.Column="1" Text="{Binding RelativeSeconds}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ArbitrationIdHex}" />
                                        <TextBlock Grid.Column="3" Text="{Binding DataHex}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Triggers">
                    <Grid Margin="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="TriggerArbIdTextBox" Width="110" Text="123" />
                            <TextBox x:Name="TriggerByteIndexTextBox" Width="60" Text="0" />
                            <ComboBox x:Name="TriggerOperatorComboBox" Width="160" />
                            <TextBox x:Name="TriggerThresholdTextBox" Width="90" Text="0" />
                            <Button Content="Add Trigger" Click="OnAddTriggerClick" />
                            <Button Content="Remove Selected" Click="OnRemoveTriggerClick" />
                        </StackPanel>
                        <ListView x:Name="TriggerListView" Grid.Row="1" ItemsSource="{Binding TriggerRows}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ArbitrationIdHex}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ByteIndex}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Operator}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Threshold}" />
                                        <TextBlock Grid.Column="4" Text="{Binding HitCount}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>
            </Pivot>
        </Border>
    </Grid>
</Window>
